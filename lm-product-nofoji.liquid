{% comment %}lm-product.liquid — LeagueMugs Arena Product Page{% endcomment %}
{% assign current_variant = product.selected_or_first_available_variant %}
{%- assign lm_size_opt = product.options_with_values | where: 'name', 'Size' | first -%}
{%- assign lm_size_idx = 0 -%}
{%- if lm_size_opt -%}{%- assign lm_size_idx = lm_size_opt.position | minus: 1 -%}{%- endif -%}
{%- assign lm_cur_size = current_variant.options[lm_size_idx] -%}

<style>
#lm-pd-{{ section.id }} {
  --ground:      #0D0D10;
  --surface:     #131318;
  --surface-2:   #1A1A22;
  --surface-3:   #222230;
  --text:        #EFE9DC;
  --text-muted:  #7C7C90;
  --text-dim:    #46465A;
  --gold:        #C8A04A;
  --gold-lt:     #DEB86A;
  --gold-fill:   rgba(200,160,74,0.10);
  --gold-border: rgba(200,160,74,0.28);
  --border:      rgba(255,255,255,0.07);
  --border-md:   rgba(255,255,255,0.12);
  --radius:      3px;
}
#lm-pd-{{ section.id }}, #lm-pd-{{ section.id }} * { box-sizing: border-box; }
.lm-breadcrumb { padding: 12px 40px; font-size: 12px; color: #9a9aae; border-bottom: 1px solid var(--border); background: var(--ground); }
.lm-breadcrumb a { color: #b6b6c4; text-decoration: none; transition: color .18s; }
.lm-breadcrumb a:hover { color: var(--gold); }
.lm-breadcrumb .lm-sep { margin: 0 8px; }
.lm-product { display: grid; grid-template-columns: 57fr 43fr; background: var(--ground); min-height: 85vh; }
.lm-gallery { position: sticky; top: 0; height: calc(100vh - 160px); min-height: 520px; display: flex; flex-direction: column; border-right: 1px solid var(--border); overflow: hidden; background: var(--ground); }
.lm-stage {
  flex: 1; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; cursor: grab;
  background: radial-gradient(ellipse 60% 52% at 50% 50%, rgba(200,160,74,0.06) 0%, rgba(200,160,74,0.02) 42%, transparent 68%), var(--ground);
  transition: background .35s;
}
.lm-stage--light {
  background: radial-gradient(ellipse 70% 60% at 50% 48%, rgba(200,160,74,0.08) 0%, rgba(200,160,74,0.03) 42%, transparent 70%), #181820;
}
.lm-stage.lm-dragging { cursor: grabbing !important; user-select: none; }

.lm-stage-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 0;
  transform: translateY(28px);
}

.lm-arrow {
  flex-shrink: 0;
  width: 38px; height: 38px;
  background: rgba(19,19,24,0.82);
  border: 1px solid var(--border-md);
  border-radius: 50%;
  color: var(--text-muted);
  font-size: 22px; line-height: 1;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background .18s, color .18s, opacity .22s, border-color .18s;
  opacity: 0.82;
  pointer-events: auto;
  user-select: none;
  margin: 0 10px;
  z-index: 4;
}
.lm-stage:hover .lm-arrow { opacity: 1; }
.lm-arrow:hover { background: var(--surface-2); border-color: var(--gold-border); color: var(--gold-lt); opacity: 1; }
.lm-arrow:active { transform: scale(0.92); }
.lm-stage.lm-dragging .lm-arrow { opacity: 0; pointer-events: none; }

.lm-main-img-wrap { width: 88%; max-width: 520px; transition: transform .4s cubic-bezier(.22,.8,.35,1); }
.lm-stage:not(.lm-dragging):hover .lm-main-img-wrap { transform: scale(1.025) translateY(-4px); }
.lm-main-img { width: 100%; height: auto; max-height: calc(100vh - 340px); object-fit: contain; display: block; margin: 0 auto; filter: drop-shadow(0 24px 48px rgba(0,0,0,.5)); transition: filter .4s; }
.lm-stage:not(.lm-dragging):hover .lm-main-img { filter: drop-shadow(0 32px 56px rgba(0,0,0,.65)); }

@keyframes lm-hint-nudge {
  0%, 100% { opacity: 0.5; transform: translateX(0); }
  25% { opacity: 0.85; transform: translateX(-4px); }
  75% { opacity: 0.85; transform: translateX(4px); }
}
.lm-rotate-hint {
  display: inline-flex; align-items: center; gap: 9px; white-space: nowrap;
  font-size: 12px; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; color: var(--text);
  background: var(--surface-2); border: 1px solid var(--gold-border); padding: 9px 20px; border-radius: 24px;
  opacity: 0.72; transition: opacity .3s; pointer-events: none;
  margin-top: 40px;
  position: relative; left: 0;
  animation: lm-hint-nudge 1.4s ease-in-out 0.8s 2;
}
.lm-rotate-hint-arrow { font-size: 20px; letter-spacing: 0; opacity: .9; color: var(--gold-lt); }
.lm-stage:hover:not(.lm-dragging) .lm-rotate-hint { opacity: 1; animation: none; }
.lm-stage.lm-dragging .lm-rotate-hint { opacity: 0 !important; animation: none; }

/* Thumbstrip */
.lm-thumbs {
  display: flex;
  gap: 8px;
  padding: 10px 14px;
  border-top: 1px solid var(--border);
  justify-content: center;
  flex-wrap: nowrap;
  overflow-x: auto;
  scrollbar-width: none;
}
.lm-thumbs::-webkit-scrollbar { display: none; }
.lm-thumb {
  flex-shrink: 0;
  width: 62px;
  height: 62px;
  border: 1.5px solid var(--border-md);
  border-radius: var(--radius);
  overflow: hidden;
  cursor: pointer;
  background: var(--surface);
  padding: 0;
  transition: border-color .18s, box-shadow .18s;
}
.lm-thumb.active {
  border-color: var(--gold);
  box-shadow: 0 0 0 1px var(--gold-border);
}
.lm-thumb:hover:not(.active) {
  border-color: rgba(255,255,255,.28);
}
.lm-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.lm-info { background: var(--ground); overflow-y: auto; max-height: 100vh; position: sticky; top: 0; scrollbar-width: thin; scrollbar-color: var(--surface-3) transparent; }
.lm-info::-webkit-scrollbar { width: 4px; }
.lm-info::-webkit-scrollbar-thumb { background: var(--surface-3); border-radius: 4px; }
.lm-info-body { padding: 32px 40px 48px; color: var(--text); font-family: -apple-system, 'Gill Sans', Arial, sans-serif; }
.lm-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-size: 10px; font-weight: 800; letter-spacing: .22em; text-transform: uppercase; color: var(--gold); margin-bottom: 14px; }
.lm-eyebrow-bar { display: block; width: 3px; height: 11px; background: var(--gold); border-radius: 2px; flex-shrink: 0; }
.lm-title { font-family: Impact, 'Franklin Gothic Heavy', 'Arial Black', sans-serif; font-size: 46px; line-height: .92; letter-spacing: .03em; text-transform: uppercase; color: var(--text); margin-bottom: 18px; word-break: break-word; }
.lm-price-row { margin-bottom: 6px; }
.lm-price-main { font-family: Impact, 'Arial Black', sans-serif; font-size: 38px; letter-spacing: .04em; color: var(--text); line-height: 1; }
.lm-price-tag { font-size: 12px; color: var(--text-muted); font-weight: 500; letter-spacing: .06em; text-transform: uppercase; margin-left: 4px; }
.lm-price-alt { font-size: 13px; color: var(--text-muted); margin-bottom: 22px; }
.lm-rule { height: 1px; margin: 22px 0; background: linear-gradient(to right, var(--gold-border) 0%, rgba(200,160,74,.06) 55%, transparent 85%); border: none; }
.lm-sel-label { display: flex; align-items: center; justify-content: space-between; font-size: 10px; font-weight: 800; letter-spacing: .18em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 10px; }
.lm-sel-val { font-size: 13px; font-weight: 400; letter-spacing: 0; text-transform: none; color: var(--text); }
.lm-color-opts { display: flex; gap: 10px; margin-bottom: 22px; }
.lm-color-btn { display: flex; align-items: center; gap: 10px; padding: 10px 16px; min-width: 116px; background: var(--surface-2); border: 1.5px solid var(--border-md); border-radius: var(--radius); cursor: pointer; color: var(--text-muted); font-size: 14px; font-weight: 500; font-family: inherit; transition: all .18s; }
.lm-color-btn:hover { color: var(--text); border-color: rgba(255,255,255,.2); }
.lm-color-btn.active { border-color: var(--gold); background: var(--gold-fill); color: var(--text); box-shadow: 0 0 0 1px var(--gold-border); }
.lm-swatch { width: 16px; height: 16px; border-radius: 50%; flex-shrink: 0; }
.lm-swatch-white { background: radial-gradient(circle at 35% 35%, #fff 0%, #ccc 100%); border: 1px solid rgba(255,255,255,.25); }
.lm-swatch-black { background: radial-gradient(circle at 35% 35%, #555 0%, #111 100%); border: 1px solid rgba(255,255,255,.15); }
.lm-size-opts { display: flex; gap: 10px; margin-bottom: 24px; }
.lm-size-btn { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 14px 8px; position: relative; background: var(--surface-2); border: 1.5px solid var(--border-md); border-radius: var(--radius); cursor: pointer; color: var(--text-muted); font-family: inherit; transition: all .18s; }
.lm-size-btn:hover { color: var(--text); border-color: rgba(255,255,255,.2); }
.lm-size-btn.active { border-color: var(--gold); background: var(--gold-fill); color: var(--text); box-shadow: 0 0 0 1px var(--gold-border); }
.lm-sz-oz { font-family: Impact, 'Arial Black', sans-serif; font-size: 26px; letter-spacing: .04em; line-height: 1; }
.lm-sz-unit { font-size: 10px; letter-spacing: .12em; text-transform: uppercase; margin-top: 2px; opacity: .7; }
.lm-sz-price { font-size: 13px; font-weight: 600; margin-top: 5px; }
.lm-popular { position: absolute; top: 0; right: 0; background: var(--gold); color: var(--ground); font-size: 8px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; padding: 3px 7px; border-radius: 0 var(--radius) 0 var(--radius); }
.lm-pers { padding: 16px; margin-bottom: 24px; border: 1px solid var(--gold-border); border-radius: var(--radius); background: var(--gold-fill); }
.lm-pers-header { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
.lm-pers-icon { font-size: 18px; line-height: 1; }
.lm-pers-title { font-size: 10px; font-weight: 800; letter-spacing: .2em; text-transform: uppercase; color: var(--gold-lt); margin: 0; }
.lm-pers-fields { display: grid; grid-template-columns: 1fr 90px; gap: 10px; }
.lm-pers-field { display: flex; flex-direction: column; gap: 5px; }
.lm-pers-label { font-size: 10px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--text-muted); }
.lm-pers-input { background: var(--surface-2); border: 1.5px solid var(--border-md); border-radius: var(--radius); color: var(--text); font-size: 14px; font-family: inherit; padding: 9px 12px; width: 100%; transition: border-color .18s; outline: none; }
.lm-pers-input::placeholder { color: var(--text-dim); }
.lm-pers-input:focus { border-color: var(--gold); }
.lm-cart-row { display: grid; grid-template-columns: 114px 1fr; gap: 10px; margin-bottom: 10px; }
.lm-qty { display: flex; align-items: stretch; background: var(--surface-2); border: 1.5px solid var(--border-md); border-radius: var(--radius); overflow: hidden; }
.lm-qty-btn { width: 34px; background: none; border: none; color: var(--text-muted); font-size: 20px; font-weight: 300; cursor: pointer; transition: color .15s; display: flex; align-items: center; justify-content: center; padding: 0; line-height: 1; }
.lm-qty-btn:hover { color: var(--text); }
.lm-qty-val { flex: 1; text-align: center; font-size: 15px; font-weight: 600; color: var(--text); display: flex; align-items: center; justify-content: center; }
.lm-atc { display: flex; align-items: center; justify-content: center; height: 52px; background: var(--gold); border: none; border-radius: var(--radius); cursor: pointer; font-family: Impact, 'Arial Black', sans-serif; font-size: 18px; letter-spacing: .1em; text-transform: uppercase; color: #0D0D10; transition: background .18s, transform .12s; width: 100%; }
.lm-atc:hover:not(:disabled) { background: var(--gold-lt); transform: translateY(-1px); }
.lm-atc:active { transform: translateY(0); }
.lm-atc:disabled { opacity: .5; cursor: not-allowed; }
.lm-atc.lm-success { background: #2D7D46; color: #fff; }
.lm-dco-wrap { margin-bottom: 22px; }
.lm-dco-or { text-align: center; font-size: 11px; color: var(--text-dim); letter-spacing: .12em; text-transform: uppercase; margin-bottom: 10px; }
.lm-trust { display: grid; grid-template-columns: repeat(3,1fr); gap: 2px; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; margin-bottom: 24px; }
.lm-trust-item { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 12px 8px; text-align: center; background: var(--surface); }
.lm-trust-ico { font-size: 18px; }
.lm-trust-label { font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-muted); line-height: 1.35; }
.lm-desc { font-size: 14px; color: var(--text-muted); line-height: 1.7; margin-bottom: 24px; border-top: 1px solid var(--border); padding-top: 22px; }
.lm-desc p { margin-bottom: 12px; }
.lm-desc p:last-child { margin-bottom: 0; }
.lm-accordion { border-top: 1px solid var(--border); }
.lm-acc-item { border-bottom: 1px solid var(--border); }
.lm-acc-trigger { width: 100%; display: flex; align-items: center; justify-content: space-between; padding: 15px 0; background: none; border: none; cursor: pointer; font-size: 11px; font-weight: 800; letter-spacing: .16em; text-transform: uppercase; color: var(--text-muted); text-align: left; transition: color .18s; font-family: inherit; }
.lm-acc-trigger:hover, .lm-acc-item.open .lm-acc-trigger { color: var(--text); }
.lm-acc-arrow { font-size: 18px; color: var(--text-dim); transition: transform .25s, color .18s; flex-shrink: 0; }
.lm-acc-item.open .lm-acc-arrow { transform: rotate(45deg); color: var(--gold); }
.lm-acc-body { overflow: hidden; max-height: 0; transition: max-height .28s ease; }
.lm-acc-item.open .lm-acc-body { max-height: 240px; }
.lm-acc-content { padding-bottom: 18px; font-size: 13px; color: var(--text-muted); line-height: 1.65; }
.lm-acc-content ul { list-style: none; display: flex; flex-direction: column; gap: 7px; padding: 0; margin: 0; }
.lm-acc-content li { display: flex; gap: 10px; align-items: flex-start; }
.lm-acc-content li::before { content: '›'; color: var(--gold); flex-shrink: 0; }
@media (max-width: 768px) {
  .lm-product { grid-template-columns: 1fr; }
  .lm-gallery { position: relative; top: auto; height: auto; }
  .lm-stage { min-height: 280px; }
  .lm-stage-center { transform: translateY(20px); }
  .lm-info { max-height: none; position: relative; }
  .lm-info-body { padding: 24px 20px 40px; }
  .lm-title { font-size: 36px; }
  .lm-breadcrumb { padding: 10px 20px; }
  .lm-arrow { width: 32px; height: 32px; font-size: 18px; margin: 0 6px; }
}
@media (prefers-reduced-motion: reduce) {
  #lm-pd-{{ section.id }} *, #lm-pd-{{ section.id }} *::before, #lm-pd-{{ section.id }} *::after { transition: none !important; animation: none !important; }
}
</style>

<div id="lm-pd-{{ section.id }}">

  <nav class="lm-breadcrumb" aria-label="Breadcrumb">
    <a href="/collections/all">Shop</a>
    {%- if collection -%}
      <span class="lm-sep" aria-hidden="true">›</span>
      <a href="{{ collection.url }}">{{ collection.title }}</a>
    {%- endif -%}
    <span class="lm-sep" aria-hidden="true">›</span>
    <span>{{ product.title }}</span>
  </nav>

  <div class="lm-product">

    <section class="lm-gallery" aria-label="Product images">
      <div class="lm-stage{% if current_variant.option1 == 'White' %} lm-stage--light{% endif %}" id="lm-stage-{{ section.id }}">
        <button class="lm-arrow lm-arrow-prev" id="lm-prev-{{ section.id }}" type="button" aria-label="Previous view">‹</button>
        <div class="lm-stage-center">
          <div class="lm-main-img-wrap">
            <img
              id="lm-main-img-{{ section.id }}"
              class="lm-main-img"
              src="{{ current_variant.featured_image | default: product.featured_image | image_url: width: 900 }}"
              alt="{{ product.title | escape }}"
              width="900"
              loading="eager"
            >
          </div>
          <div class="lm-rotate-hint" aria-hidden="true">
            <span class="lm-rotate-hint-arrow">↔</span> drag to rotate
          </div>
        </div>
        <button class="lm-arrow lm-arrow-next" id="lm-next-{{ section.id }}" type="button" aria-label="Next view">›</button>
      </div>
      {%- if product.images.size > 1 -%}
        <div class="lm-thumbs" role="list" aria-label="Product angles" aria-hidden="true">
          {%- assign active_color_count = 0 -%}
          {%- assign lm_color_opt = product.options_with_values | where: 'name', 'Color' | first -%}
          {%- for image in product.images -%}
            {%- assign img_color = 'White' -%}
            {%- if image.alt contains 'Black' -%}{%- assign img_color = 'Black' -%}{%- endif -%}
            {%- assign is_active_color = false -%}
            {%- if lm_color_opt == blank or img_color == current_variant.option1 -%}
              {%- assign is_active_color = true -%}
              {%- assign active_color_count = active_color_count | plus: 1 -%}
            {%- endif -%}
            {%- assign img_size = '' -%}
            {%- assign is_angle = true -%}
            {%- if image.alt contains '11oz' or image.alt contains '11 oz' or image.alt contains 'c11' -%}
              {%- assign img_size = '11 oz' -%}
            {%- elsif image.alt contains '15oz' or image.alt contains '15 oz' or image.alt contains 'c15' or image.alt contains '|s15' -%}
              {%- assign img_size = '15 oz' -%}
            {%- elsif image.alt contains '|feat' or image.alt contains '|right' -%}
              {%- assign img_size = '11 oz' -%}
            {%- endif -%}
            {%- if image.alt == 'c11w' or image.alt == 'c15w' -%}{%- assign is_angle = false -%}{%- endif -%}
            {%- if image.alt contains 'woman' or image.alt contains 'lifestyle' -%}{%- assign is_angle = false -%}{%- endif -%}
            <button
              class="lm-thumb{% if is_active_color and active_color_count == 1 %} active{% endif %}"
              type="button"
              data-src="{{ image | image_url: width: 900 }}"
              data-alt="{{ image.alt | escape }}"
              data-color="{{ img_color }}"
              data-size="{{ img_size }}"
              data-angle="{{ is_angle }}"
              aria-pressed="{% if is_active_color and active_color_count == 1 %}true{% else %}false{% endif %}"
              aria-label="{{ image.alt | default: 'View angle' | escape }}"
              {% unless is_active_color %}style="display:none"{% endunless %}
            >
              <img src="{{ image | image_url: width: 80 }}" alt="{{ image.alt | escape }}" loading="lazy" width="68" height="68">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </section>

    <section class="lm-info" aria-label="Product details">
      <div class="lm-info-body">

        {%- if product.type != blank -%}
          <div class="lm-eyebrow">
            <i class="lm-eyebrow-bar" aria-hidden="true"></i>
            {{ product.type }}
          </div>
        {%- endif -%}

        <h1 class="lm-title">{{ product.title }}</h1>

        <div class="lm-price-row">
          <span class="lm-price-main" id="lm-price-{{ section.id }}">{{ current_variant.price | money }}</span>
          <span class="lm-price-tag" id="lm-price-tag-{{ section.id }}">
            {%- if lm_cur_size != blank -%}{{ lm_cur_size }}{%- endif -%}
          </span>
        </div>
        {%- if product.price_min != product.price_max -%}
          <p class="lm-price-alt">From {{ product.price_min | money }}</p>
        {%- endif -%}

        <hr class="lm-rule" aria-hidden="true">

        <form action="/cart/add" method="post" id="lm-form-{{ section.id }}" novalidate>
          <input type="hidden" name="form_type" value="product">
          <input type="hidden" name="utf8" value="✓">
          <input type="hidden" name="id" id="lm-vid-{{ section.id }}" value="{{ current_variant.id }}">

          {%- assign color_opt = product.options_with_values | where: 'name', 'Color' | first -%}
          {%- if color_opt -%}
            <div class="lm-sel-label">
              Color
              <span class="lm-sel-val" id="lm-color-val-{{ section.id }}">{{ current_variant.option1 }}</span>
            </div>
            <div class="lm-color-opts" role="radiogroup" aria-label="Color">
              {%- for val in color_opt.values -%}
                <button
                  type="button"
                  class="lm-color-btn{% if val == current_variant.option1 %} active{% endif %}"
                  data-opt-pos="{{ color_opt.position | minus: 1 }}"
                  data-val="{{ val | escape }}"
                  aria-pressed="{% if val == current_variant.option1 %}true{% else %}false{% endif %}"
                >
                  <span class="lm-swatch lm-swatch-{{ val | downcase | replace: ' ', '-' }}" aria-hidden="true"></span>
                  {{ val }}
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- assign size_opt = product.options_with_values | where: 'name', 'Size' | first -%}
          {%- if size_opt -%}
            <div class="lm-sel-label">
              Size
              <span class="lm-sel-val" id="lm-size-val-{{ section.id }}">{{ lm_cur_size }}</span>
            </div>
            <div class="lm-size-opts" role="radiogroup" aria-label="Size">
              {%- for val in size_opt.values -%}
                {%- assign oz_num = val | remove: ' oz' | remove: 'oz' | strip -%}
                {%- assign sz_price = '' -%}
                {%- for v in product.variants -%}
                  {%- if v.option2 == val or v.option1 == val -%}{%- assign sz_price = v.price | money -%}{%- break -%}{%- endif -%}
                {%- endfor -%}
                <button
                  type="button"
                  class="lm-size-btn{% if val == lm_cur_size %} active{% endif %}"
                  data-opt-pos="{{ size_opt.position | minus: 1 }}"
                  data-val="{{ val | escape }}"
                  aria-pressed="{% if val == lm_cur_size %}true{% else %}false{% endif %}"
                >
                  {%- if val contains '15' -%}<span class="lm-popular">Popular</span>{%- endif -%}
                  <span class="lm-sz-oz">{{ oz_num }}</span>
                  <span class="lm-sz-unit">oz{%- if val contains '15' %} · Big League{%- endif -%}</span>
                  {%- if sz_price != '' -%}<span class="lm-sz-price">{{ sz_price }}</span>{%- endif -%}
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if product.tags contains 'personalizable' -%}
          <div class="lm-pers">
            <div class="lm-pers-header">
              <span class="lm-pers-icon" aria-hidden="true">🏆</span>
              <h4 class="lm-pers-title">Personalize Your Mug</h4>
            </div>
            <div class="lm-pers-fields">
              <div class="lm-pers-field">
                <label class="lm-pers-label" for="lm-teamname-{{ section.id }}">Team Name</label>
                <input class="lm-pers-input" type="text" id="lm-teamname-{{ section.id }}" name="properties[Team Name]" placeholder="e.g. The Gridiron Gods" maxlength="25" autocomplete="off">
              </div>
              <div class="lm-pers-field">
                <label class="lm-pers-label" for="lm-year-{{ section.id }}">Year</label>
                <input class="lm-pers-input" type="text" id="lm-year-{{ section.id }}" name="properties[Year]" placeholder="2025" maxlength="4" pattern="[0-9]{4}" inputmode="numeric" autocomplete="off">
              </div>
            </div>
          </div>
          {%- endif -%}

          <div class="lm-cart-row">
            <div class="lm-qty" role="group" aria-label="Quantity">
              <button type="button" class="lm-qty-btn" id="lm-qm-{{ section.id }}" aria-label="Decrease">−</button>
              <div class="lm-qty-val" id="lm-qd-{{ section.id }}" aria-live="polite">1</div>
              <button type="button" class="lm-qty-btn" id="lm-qp-{{ section.id }}" aria-label="Increase">+</button>
              <input type="hidden" name="quantity" id="lm-qty-{{ section.id }}" value="1">
            </div>
            <button
              type="submit"
              class="lm-atc"
              id="lm-atc-{{ section.id }}"
              name="add"
              {%- unless current_variant.available %} disabled{%- endunless -%}
            >
              {%- if current_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
            </button>
          </div>
        </form>

        {%- if additional_checkout_buttons -%}
          <div class="lm-dco-wrap">
            <p class="lm-dco-or">or</p>
            {{ content_for_additional_checkout_buttons }}
          </div>
        {%- endif -%}

        <div class="lm-trust">
          <div class="lm-trust-item"><div class="lm-trust-ico">🍽</div><div class="lm-trust-label">Dishwasher<br>Safe</div></div>
          <div class="lm-trust-item"><div class="lm-trust-ico">🚚</div><div class="lm-trust-label">Free US Ship<br>Over $50</div></div>
          <div class="lm-trust-item"><div class="lm-trust-ico">🎨</div><div class="lm-trust-label">Made to<br>Order</div></div>
        </div>

        {%- if product.description != blank -%}
          <div class="lm-desc">{{ product.description }}</div>
        {%- endif -%}

        <div class="lm-accordion">
          <div class="lm-acc-item open">
            <button class="lm-acc-trigger" type="button" aria-expanded="true">Product Details<span class="lm-acc-arrow" aria-hidden="true">+</span></button>
            <div class="lm-acc-body"><div class="lm-acc-content"><ul>
              <li>Ceramic mug in 11 oz and 15 oz</li>
              <li>Full wraparound print on both sides</li>
              <li>Dishwasher and microwave safe</li>
            </ul></div></div>
          </div>
          <div class="lm-acc-item">
            <button class="lm-acc-trigger" type="button" aria-expanded="false">Personalization<span class="lm-acc-arrow" aria-hidden="true">+</span></button>
            <div class="lm-acc-body"><div class="lm-acc-content"><p>Add your league name and founding year in the order notes at checkout. We print exactly what you write, so double-check spelling. Once in production we can't make changes.</p></div></div>
          </div>
          <div class="lm-acc-item">
            <button class="lm-acc-trigger" type="button" aria-expanded="false">Shipping &amp; Returns<span class="lm-acc-arrow" aria-hidden="true">+</span></button>
            <div class="lm-acc-body"><div class="lm-acc-content"><ul>
              <li>Free US shipping on orders over $50</li>
              <li>Production: 3 to 5 business days</li>
              <li>Made to order just for you</li>
            </ul></div></div>
          </div>
        </div>

      </div>
    </section>
  </div>
</div>

<script type="application/json" id="lm-variants-{{ section.id }}">
  {{ product.variants | json }}
</script>
<script>
(function(){
  var SID = '{{ section.id }}';
  var VARIANTS = JSON.parse(document.getElementById('lm-variants-' + SID).textContent);
  var root = document.getElementById('lm-pd-' + SID);
  if (!root) return;
  {%- assign lm_has_color = product.options_with_values | where: 'name', 'Color' | first -%}
  {%- assign lm_color_idx = 0 -%}
  {%- if lm_has_color -%}{%- assign lm_color_idx = lm_has_color.position | minus: 1 -%}{%- endif -%}
  var HAS_COLOR = {% if lm_has_color %}true{% else %}false{% endif %};
  var SIZE_IDX = {{ lm_size_idx }};
  var COLOR_IDX = {{ lm_color_idx }};

  var sel = [
    '{{ current_variant.option1 | escape }}',
    '{{ current_variant.option2 | escape }}',
    '{{ current_variant.option3 | escape }}'
  ];
  var qty = 1;

  function findVariant() {
    return VARIANTS.find(function(v) {
      return (!v.option1 || v.option1 === sel[0]) &&
             (!v.option2 || v.option2 === sel[1]) &&
             (!v.option3 || v.option3 === sel[2]);
    });
  }

  function money(cents) {
    if (window.Shopify && Shopify.formatMoney) return Shopify.formatMoney(cents, '${{amount}}');
    return '$' + (cents / 100).toFixed(2).replace(/\.00$/, '');
  }

  function updateUI(v) {
    if (!v) return;
    var sizeVal = v.options[SIZE_IDX];
    var vidEl = document.getElementById('lm-vid-' + SID);
    if (vidEl) vidEl.value = v.id;
    var prEl = document.getElementById('lm-price-' + SID);
    if (prEl) prEl.textContent = money(v.price);
    var tagEl = document.getElementById('lm-price-tag-' + SID);
    if (tagEl && sizeVal) tagEl.textContent = sizeVal;
    var szLbl = document.getElementById('lm-size-val-' + SID);
    if (szLbl && sizeVal) szLbl.textContent = sizeVal;
    var atc = document.getElementById('lm-atc-' + SID);
    if (atc && !atc.classList.contains('lm-success')) {
      atc.disabled = !v.available;
      atc.textContent = v.available ? 'Add to Cart' : 'Sold Out';
    }
    if (v.featured_image) {
      var img = document.getElementById('lm-main-img-' + SID);
      if (img) {
        var src = v.featured_image.src;
        img.src = src + (src.indexOf('?') > -1 ? '&' : '?') + 'width=900';
        if (v.featured_image.alt) img.alt = v.featured_image.alt;
      }
    }
    if (history.replaceState) {
      var u = new URL(window.location.href);
      u.searchParams.set('variant', v.id);
      history.replaceState({}, '', u.toString());
    }
  }

  function syncThumbs(resetActive) {
    var currentColor = HAS_COLOR ? (sel[COLOR_IDX] || 'White') : 'White';
    var currentSize  = sel[SIZE_IDX] || '';
    var firstThumb = null;
    root.querySelectorAll('.lm-thumb').forEach(function(t) {
      var tc = t.dataset.color || 'White';
      var ts = t.dataset.size || '';
      var show = HAS_COLOR ? (tc === currentColor) : true;
      if (show && ts && currentSize) show = (ts === currentSize);
      t.style.display = show ? '' : 'none';
      if (resetActive) { t.classList.remove('active'); t.setAttribute('aria-pressed','false'); }
      if (show && !firstThumb) firstThumb = t;
    });
    if (resetActive && firstThumb) {
      firstThumb.classList.add('active'); firstThumb.setAttribute('aria-pressed','true');
      var img = document.getElementById('lm-main-img-' + SID);
      if (img) { img.src = firstThumb.dataset.src; if (firstThumb.dataset.alt) img.alt = firstThumb.dataset.alt; }
    }
  }
  syncThumbs(false);

  root.querySelectorAll('.lm-color-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var pos = parseInt(this.dataset.optPos);
      sel[pos] = this.dataset.val;
      root.querySelectorAll('.lm-color-btn').forEach(function(b) { b.classList.remove('active'); b.setAttribute('aria-pressed','false'); });
      this.classList.add('active'); this.setAttribute('aria-pressed','true');
      var lbl = document.getElementById('lm-color-val-' + SID);
      if (lbl) lbl.textContent = this.dataset.val;
      var stage = document.getElementById('lm-stage-' + SID);
      if (stage) stage.classList.toggle('lm-stage--light', this.dataset.val === 'White');
      syncThumbs(true);
      updateUI(findVariant());
    });
  });

  root.querySelectorAll('.lm-size-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var pos = parseInt(this.dataset.optPos);
      sel[pos] = this.dataset.val;
      root.querySelectorAll('.lm-size-btn').forEach(function(b) { b.classList.remove('active'); b.setAttribute('aria-pressed','false'); });
      this.classList.add('active'); this.setAttribute('aria-pressed','true');
      var lbl = document.getElementById('lm-size-val-' + SID);
      if (lbl) lbl.textContent = this.dataset.val;
      syncThumbs(true);
      updateUI(findVariant());
    });
  });

  root.querySelectorAll('.lm-thumb').forEach(function(btn) {
    btn.addEventListener('click', function() {
      root.querySelectorAll('.lm-thumb').forEach(function(t) { t.classList.remove('active'); t.setAttribute('aria-pressed','false'); });
      this.classList.add('active'); this.setAttribute('aria-pressed','true');
      var img = document.getElementById('lm-main-img-' + SID);
      if (img) { img.src = this.dataset.src; if (this.dataset.alt) img.alt = this.dataset.alt; }
    });
  });

  var qtyInp = document.getElementById('lm-qty-' + SID);
  var qtyDisp = document.getElementById('lm-qd-' + SID);
  var qm = document.getElementById('lm-qm-' + SID);
  var qp = document.getElementById('lm-qp-' + SID);
  if (qm) qm.addEventListener('click', function() { qty = Math.max(1, qty - 1); if (qtyInp) qtyInp.value = qty; if (qtyDisp) qtyDisp.textContent = qty; });
  if (qp) qp.addEventListener('click', function() { qty++; if (qtyInp) qtyInp.value = qty; if (qtyDisp) qtyDisp.textContent = qty; });

  // Personalization sanitize: allow letters/numbers/punctuation/spaces only — block emoji & other symbols.
  function lmCleanName(s){ return (s || '').replace(/[^\p{L}\p{N}\p{P}\p{Zs}]/gu, '').replace(/\s+/g, ' ').trim(); }
  (function(){
    var t = document.getElementById('lm-teamname-' + SID);
    if (t) t.addEventListener('input', function(){ var c = this.value.replace(/[^\p{L}\p{N}\p{P}\p{Zs}]/gu, ''); if (c !== this.value) this.value = c; });
    var y = document.getElementById('lm-year-' + SID);
    if (y) y.addEventListener('input', function(){ var c = this.value.replace(/\D/g, '').slice(0, 4); if (c !== this.value) this.value = c; });
  })();

  var form = document.getElementById('lm-form-' + SID);
  var atcBtn = document.getElementById('lm-atc-' + SID);
  if (form && atcBtn) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var vid = document.getElementById('lm-vid-' + SID).value;
      var teamEl = document.getElementById('lm-teamname-' + SID);
      var yearEl = document.getElementById('lm-year-' + SID);
      var props = {};
      if (teamEl && lmCleanName(teamEl.value)) props['Team Name'] = lmCleanName(teamEl.value);
      if (yearEl && yearEl.value.replace(/\D/g,'')) props['Year'] = yearEl.value.replace(/\D/g,'').slice(0,4);
      atcBtn.textContent = 'Adding…'; atcBtn.disabled = true;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: {'Content-Type':'application/json','Accept':'application/json'},
        body: JSON.stringify({id: parseInt(vid), quantity: qty, properties: props})
      }).then(function(r){ return r.json(); }).then(function(d) {
        if (d.status) {
          atcBtn.textContent = d.description || 'Error, try again'; atcBtn.disabled = false;
          setTimeout(function(){ atcBtn.textContent = 'Add to Cart'; }, 2500);
        } else {
          atcBtn.textContent = '✓ Added!'; atcBtn.classList.add('lm-success'); atcBtn.disabled = false;
          setTimeout(function(){ atcBtn.textContent = 'Add to Cart'; atcBtn.classList.remove('lm-success'); }, 2500);
          ['cart:refresh','cart:update','theme:cart-update'].forEach(function(ev){ document.dispatchEvent(new CustomEvent(ev)); });
        }
      }).catch(function(){ atcBtn.textContent = 'Error, try again'; atcBtn.disabled = false; setTimeout(function(){ atcBtn.textContent = 'Add to Cart'; }, 2500); });
    });
  }

  root.querySelectorAll('.lm-acc-trigger').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = this.closest('.lm-acc-item');
      var wasOpen = item.classList.contains('open');
      root.querySelectorAll('.lm-acc-item.open').forEach(function(i){ i.classList.remove('open'); i.querySelector('.lm-acc-trigger').setAttribute('aria-expanded','false'); });
      if (!wasOpen) { item.classList.add('open'); this.setAttribute('aria-expanded','true'); }
    });
  });

  (function() {
    var stage   = document.getElementById('lm-stage-' + SID);
    var imgEl   = document.getElementById('lm-main-img-' + SID);
    var wrap    = imgEl ? imgEl.parentElement : null;
    var prevBtn = document.getElementById('lm-prev-' + SID);
    var nextBtn = document.getElementById('lm-next-' + SID);
    if (!stage || !imgEl || !wrap) return;

    var dragStartX = 0;
    var baseIndex  = 0;
    var thumbs     = [];
    var didDrag    = false;
    var STEP       = 80;

    function visibleThumbs() {
      var currentSize = sel[SIZE_IDX] || '';
      return Array.from(root.querySelectorAll('.lm-thumb')).filter(function(t) {
        if (t.style.display === 'none') return false;
        if (t.dataset.angle === 'false') return false;
        var tSize = t.dataset.size || '';
        if (tSize && currentSize && tSize !== currentSize) return false;
        return true;
      });
    }

    function activeIndex(list) {
      for (var i = 0; i < list.length; i++) {
        if (list[i].classList.contains('active')) return i;
      }
      return 0;
    }

    function showThumb(t) {
      thumbs.forEach(function(x) { x.classList.remove('active'); x.setAttribute('aria-pressed','false'); });
      t.classList.add('active'); t.setAttribute('aria-pressed','true');
      imgEl.src = t.dataset.src;
      if (t.dataset.alt) imgEl.alt = t.dataset.alt;
    }

    function updateArrows() {
      var list = visibleThumbs();
      var show = list.length >= 2;
      if (prevBtn) prevBtn.style.visibility = show ? '' : 'hidden';
      if (nextBtn) nextBtn.style.visibility = show ? '' : 'hidden';
    }
    updateArrows();

    if (prevBtn) prevBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      thumbs = visibleThumbs();
      if (thumbs.length < 2) return;
      var idx = (activeIndex(thumbs) - 1 + thumbs.length) % thumbs.length;
      showThumb(thumbs[idx]);
      stage.classList.add('lm-rotated');
    });
    if (nextBtn) nextBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      thumbs = visibleThumbs();
      if (thumbs.length < 2) return;
      var idx = (activeIndex(thumbs) + 1) % thumbs.length;
      showThumb(thumbs[idx]);
      stage.classList.add('lm-rotated');
    });

    function onStart(e) {
      if (e.target.classList.contains('lm-arrow')) return;
      thumbs = visibleThumbs();
      if (thumbs.length < 2) return;
      dragStartX = e.type === 'touchstart' ? e.touches[0].clientX : e.clientX;
      baseIndex  = activeIndex(thumbs);
      didDrag    = false;
      stage.classList.add('lm-dragging');
      wrap.style.transition = 'none';
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup',   onEnd);
      document.addEventListener('touchmove', onMove, { passive: true });
      document.addEventListener('touchend',  onEnd);
    }

    function onMove(e) {
      var cx = e.type === 'touchmove' ? e.touches[0].clientX : e.clientX;
      var dx = cx - dragStartX;
      if (Math.abs(dx) > 8) didDrag = true;
      wrap.style.transform = 'translateX(' + Math.max(-14, Math.min(14, dx * 0.06)) + 'px)';
      var steps = -Math.round(dx / STEP);
      var idx = ((baseIndex + steps) % thumbs.length + thumbs.length) % thumbs.length;
      if (idx !== activeIndex(thumbs)) showThumb(thumbs[idx]);
    }

    function onEnd() {
      stage.classList.remove('lm-dragging');
      wrap.style.transition = 'transform .28s cubic-bezier(.22,.8,.35,1)';
      wrap.style.transform  = '';
      if (didDrag) stage.classList.add('lm-rotated');
      setTimeout(function() { wrap.style.transition = ''; }, 300);
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup',   onEnd);
      document.removeEventListener('touchmove', onMove);
      document.removeEventListener('touchend',  onEnd);
      setTimeout(function() { didDrag = false; }, 0);
    }

    stage.addEventListener('mousedown',  onStart);
    stage.addEventListener('touchstart', onStart, { passive: true });
    stage.addEventListener('click', function(e) {
      if (didDrag && !e.target.closest('.lm-arrow')) e.stopPropagation();
    }, true);

    root.querySelectorAll('.lm-color-btn, .lm-size-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        stage.classList.remove('lm-rotated');
        setTimeout(updateArrows, 20);
      });
    });
  })();

})();
</script>

