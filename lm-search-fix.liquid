{% comment %}lm-search.liquid — LeagueMugs Search Results (branded, product-focused, numbered pagination){% endcomment %}
<style>
@import url("https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap");
.lm-srch{
  --ground:#FAFAFA;--surface:#FFFFFF;--cream:#F5F0E8;--ob:#0D0D0D;--text:#18181B;--muted:#71717A;--dim:#A1A1AA;
  --gold:#C9A84C;--gold-lt:#D8B85A;--gold-fill:rgba(201,168,76,.08);--gold-border:rgba(201,168,76,.35);
  --border:#E4E4E7;--border-md:#D4D4D8;--radius:3px;
  background:var(--ground);font-family:"Inter",-apple-system,system-ui,sans-serif;color:var(--text);
}
.lm-srch *{box-sizing:border-box;margin:0}
.lm-srch-wrap{max-width:1320px;margin:0 auto;padding:0 40px}

/* HERO */
.lm-srch-hero{background:linear-gradient(155deg,#1A1A2E 0%,#141425 45%,#0D0D0D 100%);
  position:relative;left:50%;right:50%;width:100vw;margin-left:-50vw;margin-right:-50vw}
.lm-srch-hero-in{max-width:1320px;margin:0 auto;padding:46px 40px 42px;text-align:center}
.lm-srch-eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:10px;font-weight:800;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:10px}
.lm-srch-title{font-family:"Barlow Condensed",Impact,sans-serif;font-weight:800;font-size:46px;line-height:.94;letter-spacing:.02em;text-transform:uppercase;color:#fff;margin:0 0 6px}
.lm-srch-rule{width:60px;height:2px;background:var(--gold);margin:0 auto 22px}
.lm-srch-form{display:flex;gap:10px;max-width:560px;margin:0 auto}
.lm-srch-input{flex:1;min-width:0;padding:15px 18px;border-radius:var(--radius);border:1px solid rgba(255,255,255,.2);
  background:#fff;color:#18181B;font-family:"Inter",sans-serif;font-size:15px;transition:border-color .18s}
.lm-srch-input::placeholder{color:#9A9AA5}
.lm-srch-input:focus{outline:none;border-color:var(--gold)}
.lm-srch-btn{border:0;cursor:pointer;font-family:"Barlow Condensed",Impact,sans-serif;font-weight:800;text-transform:uppercase;
  letter-spacing:.08em;font-size:15px;padding:0 26px;border-radius:var(--radius);background:var(--gold);color:var(--ob);transition:background .18s}
.lm-srch-btn:hover{background:var(--gold-lt)}

.lm-srch-meta{padding:28px 0 4px;font-size:13px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
.lm-srch-meta b{color:var(--text)}

/* GRID (shared card look with collection) */
.lm-srch-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:24px;list-style:none;margin:22px 0 0;padding:0}
.lm-srch-grid > li{display:flex}
.lm-srch-card{background:var(--surface);width:100%;min-width:0;border:1px solid var(--border);border-radius:12px;overflow:hidden;
  text-decoration:none;color:inherit;display:flex;flex-direction:column;transition:transform .2s,box-shadow .2s,border-color .2s;box-shadow:0 2px 8px rgba(13,13,13,.05)}
.lm-srch-card:hover{transform:translateY(-4px);box-shadow:0 16px 34px rgba(13,13,13,.12);border-color:var(--gold-border)}
.lm-srch-img-box{position:relative;aspect-ratio:1/1;overflow:hidden;display:flex;align-items:center;justify-content:center;
  background:radial-gradient(ellipse 68% 60% at 50% 52%,rgba(201,168,76,.07) 0%,transparent 68%),var(--cream)}
.lm-srch-img{width:80%;height:80%;object-fit:contain;display:block;transition:transform .35s cubic-bezier(.22,.8,.35,1)}
.lm-srch-card:hover .lm-srch-img{transform:scale(1.05)}
.lm-srch-body{padding:15px 16px 18px;border-top:1px solid var(--border);flex:1;display:flex;flex-direction:column;transition:border-color .2s}
.lm-srch-card:hover .lm-srch-body{border-color:var(--gold-border)}
.lm-srch-cat{font-weight:600;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--dim)}
.lm-srch-name{font-family:"Barlow Condensed",Impact,sans-serif;font-weight:700;font-size:18px;line-height:1.15;letter-spacing:.03em;text-transform:uppercase;color:var(--text);margin:6px 0 9px;transition:color .18s;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;min-height:2.3em}
.lm-srch-card:hover .lm-srch-name{color:var(--gold-lt)}
.lm-srch-price{font-family:"Barlow Condensed",Impact,sans-serif;font-weight:800;font-size:20px;color:var(--text);margin-top:auto}
.lm-srch-price small{font-family:"Inter",sans-serif;font-weight:500;font-size:11px;color:var(--muted);letter-spacing:.04em;margin-right:4px;text-transform:uppercase}

/* PAGINATION */
.lm-srch-pg{display:flex;align-items:center;justify-content:center;gap:6px;flex-wrap:wrap;padding:44px 0 8px}
.lm-srch-pg a,.lm-srch-pg span{display:inline-flex;align-items:center;justify-content:center;min-width:42px;height:42px;padding:0 8px;
  font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:16px;letter-spacing:.04em;border-radius:var(--radius);text-decoration:none;transition:.16s}
.lm-srch-pg a{color:var(--text);border:1.5px solid var(--border-md);background:var(--surface)}
.lm-srch-pg a:hover{border-color:var(--gold);background:var(--gold-fill);color:var(--gold-lt)}
.lm-srch-pg .cur{background:#0D0D0D;color:var(--gold);border:1.5px solid #0D0D0D}
.lm-srch-pg .gap{border:0;background:none;color:var(--dim);min-width:24px}
.lm-srch-pg .arw{font-size:13px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:0 16px}

/* EMPTY */
.lm-srch-empty{padding:64px 0 72px;text-align:center;max-width:520px;margin:0 auto}
.lm-srch-empty img{width:150px;height:auto;margin:0 auto 8px;filter:drop-shadow(0 14px 28px rgba(0,0,0,.18))}
.lm-srch-empty-title{font-family:"Barlow Condensed",Impact,sans-serif;font-weight:800;font-size:30px;letter-spacing:.03em;text-transform:uppercase;color:var(--text);margin-bottom:10px}
.lm-srch-empty-msg{font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:22px}
.lm-srch-pills{display:flex;gap:10px;flex-wrap:wrap;justify-content:center}
.lm-srch-pill{font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;padding:9px 18px;border-radius:30px;
  border:1px solid var(--border-md);color:var(--text);text-decoration:none;transition:.15s}
.lm-srch-pill:hover{border-color:var(--gold);color:var(--gold-lt);background:var(--gold-fill)}

@media(max-width:1100px){.lm-srch-grid{grid-template-columns:repeat(3,minmax(0,1fr))}}
@media(max-width:760px){.lm-srch-wrap{padding:0 22px}.lm-srch-hero-in{padding:36px 22px 34px}.lm-srch-grid{grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}.lm-srch-title{font-size:36px}}
@media(prefers-reduced-motion:reduce){.lm-srch *,.lm-srch *::before,.lm-srch *::after{transition:none!important}}
</style>

<div class="lm-srch">

  <section class="lm-srch-hero">
    <div class="lm-srch-hero-in">
      <div class="lm-srch-eyebrow">Find Your Mug</div>
      <h1 class="lm-srch-title">{%- if search.performed and search.terms != blank -%}Search Results{%- else -%}Search the Locker Room{%- endif -%}</h1>
      <div class="lm-srch-rule"></div>
      <form class="lm-srch-form" action="{{ routes.search_url }}" method="get" role="search">
        <input type="hidden" name="type" value="product">
        <input class="lm-srch-input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search champions, the Sacko, your team name&hellip;" autocomplete="off" aria-label="Search">
        <button class="lm-srch-btn" type="submit">Search</button>
      </form>
    </div>
  </section>

  <div class="lm-srch-wrap">

    {%- if search.performed -%}
      {%- comment -%} count product results {%- endcomment -%}
      {%- assign product_total = 0 -%}
      {%- for item in search.results -%}{%- if item.object_type == 'product' -%}{%- assign product_total = product_total | plus: 1 -%}{%- endif -%}{%- endfor -%}

      {%- if search.results_count == 0 -%}
        <div class="lm-srch-empty">
          <img src="https://cdn.shopify.com/s/files/1/0999/3974/6156/files/crown_11_left.png?v=1782170597" alt="No results">
          <p class="lm-srch-empty-title">No mugs match &ldquo;{{ search.terms | escape }}&rdquo;</p>
          <p class="lm-srch-empty-msg">Check the spelling, or browse the trophy shelf instead. Try &ldquo;champion,&rdquo; &ldquo;sacko,&rdquo; or your sport.</p>
          <div class="lm-srch-pills">
            <a class="lm-srch-pill" href="/collections/champions">Champions</a>
            <a class="lm-srch-pill" href="/collections/the-sacko">The Roast</a>
            <a class="lm-srch-pill" href="/collections/specialty-roles">Personality</a>
            <a class="lm-srch-pill" href="/collections/all">Shop All</a>
          </div>
        </div>
      {%- else -%}
        <p class="lm-srch-meta"><b>{{ search.results_count }}</b> result{{ search.results_count | pluralize: '', 's' }} for &ldquo;{{ search.terms | escape }}&rdquo;</p>

        {%- paginate search.results by 24 -%}
        <ul class="lm-srch-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              <li>
                <a class="lm-srch-card" href="{{ item.url }}" aria-label="{{ item.title | escape }}">
                  <div class="lm-srch-img-box">
                    <img class="lm-srch-img" src="{{ item.featured_image | image_url: width: 600 }}" alt="{{ item.featured_image.alt | default: item.title | escape }}" loading="lazy" width="600" height="600">
                  </div>
                  <div class="lm-srch-body">
                    <div class="lm-srch-cat">{{ item.type | default: 'Fantasy Mug' }}</div>
                    <div class="lm-srch-name">{{ item.title | remove: ' Mug' }}</div>
                    <div class="lm-srch-price">{%- if item.price_varies -%}<small>From</small>{%- endif -%}{{ item.price_min | money }}</div>
                  </div>
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>

        {%- if paginate.pages > 1 -%}
          <nav class="lm-srch-pg" aria-label="Pagination">
            {%- if paginate.previous -%}<a class="arw" href="{{ paginate.previous.url }}" rel="prev">&lsaquo; Prev</a>{%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}{%- if part.title == paginate.current_page -%}<span class="cur">{{ part.title }}</span>{%- else -%}<span class="gap">{{ part.title }}</span>{%- endif -%}{%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}<a class="arw" href="{{ paginate.next.url }}" rel="next">Next &rsaquo;</a>{%- endif -%}
          </nav>
        {%- endif -%}
        {%- endpaginate -%}
      {%- endif -%}

    {%- else -%}
      <div class="lm-srch-empty">
        <p class="lm-srch-empty-title">What are you hunting for?</p>
        <p class="lm-srch-empty-msg">Search the full lineup, or jump straight to a collection.</p>
        <div class="lm-srch-pills">
          <a class="lm-srch-pill" href="/collections/champions">Champions</a>
          <a class="lm-srch-pill" href="/collections/the-sacko">The Roast</a>
          <a class="lm-srch-pill" href="/collections/specialty-roles">Personality</a>
          <a class="lm-srch-pill" href="/collections/all">Shop All</a>
        </div>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "LM Search",
  "tag": "section",
  "class": "lm-search-section",
  "settings": [],
  "presets": [{ "name": "LM Search" }]
}
{% endschema %}
