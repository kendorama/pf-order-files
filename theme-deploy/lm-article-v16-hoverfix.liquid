{% comment %}lm-article.liquid — LeagueMugs Article Page{% endcomment %}
<style>
.lm-art {
  --ground: #0D0D10; --surface: #131318; --surface-2: #1A1A22;
  --text: #EFE9DC; --text-muted: #7C7C90; --text-dim: #46465A;
  --gold: #C8A04A; --gold-lt: #DEB86A; --gold-fill: rgba(200,160,74,0.07);
  --gold-border: rgba(200,160,74,0.28); --border: rgba(255,255,255,0.07);
  --border-md: rgba(255,255,255,0.12); --radius: 3px;
  background: var(--ground); font-family: -apple-system,'Gill Sans',Arial,sans-serif; color: var(--text);
}
.lm-art * { box-sizing: border-box; }

.lm-art-breadcrumb {
  padding: 14px 48px; font-size: 12px; color: var(--text-dim);
  border-bottom: 1px solid var(--border); background: var(--ground);
  display: flex; align-items: center; gap: 8px;
}
.lm-art-breadcrumb a { color: var(--text-dim); text-decoration: none; transition: color .18s; }
.lm-art-breadcrumb a:hover { color: var(--gold); }
.lm-art-breadcrumb-sep { color: var(--text-dim); }

.lm-art-hero { position: relative; overflow: hidden; max-height: 480px; }
.lm-art-hero img { width: 100%; height: 100%; object-fit: cover; display: block; max-height: 480px; }
.lm-art-hero-placeholder {
  height: 320px;
  background:
    radial-gradient(ellipse 60% 70% at 50% 42%,rgba(200,160,74,.12) 0%,transparent 62%),
    linear-gradient(180deg,var(--surface) 0%,var(--ground) 100%);
  display: flex; align-items: center; justify-content: center;
  border-bottom: 1px solid var(--gold-border);
}
.lm-plate { display: flex; flex-direction: column; align-items: center; gap: 16px; }
.lm-plate-lockup {
  display: flex; align-items: center; gap: 14px;
  font-family: Impact,'Franklin Gothic Heavy','Arial Black',sans-serif;
  font-size: 46px; line-height: 1; letter-spacing: .05em; text-transform: uppercase; color: var(--gold-lt);
}
.lm-plate-lockup .lm-plate-trophy { font-size: 40px; }
.lm-plate-rule { width: 72px; height: 2px; background: linear-gradient(to right,transparent,var(--gold),transparent); }
.lm-plate-sub { font-size: 11px; font-weight: 800; letter-spacing: .28em; text-transform: uppercase; color: var(--text-dim); }

.lm-art-body { max-width: 760px; margin: 0 auto; padding: 52px 48px 80px; }

.lm-art-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 10px; font-weight: 800; letter-spacing: .22em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 16px;
}
.lm-art-eyebrow-bar { display: block; width: 3px; height: 11px; background: var(--gold); border-radius: 2px; }

.lm-art-title {
  font-family: Impact,'Franklin Gothic Heavy','Arial Black',sans-serif;
  font-size: 52px; line-height: .88; letter-spacing: .04em; text-transform: uppercase;
  color: var(--text); margin: 0 0 24px;
}

.lm-art-meta {
  display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--text-dim);
  padding-bottom: 28px; border-bottom: 1px solid var(--border); margin-bottom: 40px;
}
.lm-art-meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--gold); display: inline-block; }

.lm-art-tags { display: flex; flex-wrap: wrap; gap: 8px; }
.lm-art-tag {
  padding: 3px 10px; border: 1px solid var(--border-md);
  font-size: 10px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase;
  color: var(--text-dim); border-radius: 20px;
}

/* Article body prose */
.lm-art-content { font-size: 17px; line-height: 1.75; color: var(--text-muted); }
.lm-art-content p { margin: 0 0 1.5em; }
.lm-art-content p:last-child { margin-bottom: 0; }
.lm-art-content h2 {
  font-family: Impact,'Franklin Gothic Heavy','Arial Black',sans-serif;
  font-size: 28px; line-height: 1.0; letter-spacing: .04em; text-transform: uppercase;
  color: var(--text); margin: 2em 0 .75em;
}
.lm-art-content h3 {
  font-size: 16px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
  color: var(--text); margin: 1.8em 0 .6em;
}
.lm-art-content ul, .lm-art-content ol { padding-left: 0; list-style: none; margin: 0 0 1.5em; }
.lm-art-content li { padding-left: 20px; position: relative; margin-bottom: .7em; }
.lm-art-content ul li::before { content: '—'; position: absolute; left: 0; color: var(--gold); font-weight: 700; }
.lm-art-content ol { counter-reset: lm-ol; }
.lm-art-content ol li::before { content: counter(lm-ol); counter-increment: lm-ol; position: absolute; left: 0; color: var(--gold); font-weight: 800; font-size: 13px; }
.lm-art-content a { color: var(--gold); text-decoration: underline; text-decoration-color: var(--gold-border); transition: color .18s; }
/* Force gold hover — theme base.css has a nested `&:hover` rule (0,3,2 specificity via the .rte branch) that otherwise turns in-prose links to dark foreground/0.7 → near-black on the dark article. !important guarantees the gold state wins. */
.lm-art-content a:hover,
.lm-art-content a:focus { color: var(--gold-lt) !important; text-decoration-color: var(--gold) !important; }
.lm-art-content strong { color: var(--text); font-weight: 700; }
.lm-art-content blockquote {
  border-left: 3px solid var(--gold); padding: 12px 20px;
  margin: 1.5em 0; background: var(--gold-fill); border-radius: 0 var(--radius) var(--radius) 0;
  font-style: italic; color: var(--text);
}
.lm-art-content hr { border: none; height: 1px; background: var(--border); margin: 2.5em 0; }

.lm-art-rule { height: 1px; background: linear-gradient(to right,var(--gold-border) 0%,rgba(200,160,74,.06) 55%,transparent 85%); border: none; margin: 48px 0 40px; }

/* Bottom CTA */
.lm-art-cta {
  padding: 28px 32px; border: 1px solid var(--gold-border);
  border-radius: var(--radius); background: var(--gold-fill);
  display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;
}
.lm-art-cta-text {
  font-family: Impact,'Arial Black',sans-serif;
  font-size: 20px; line-height: 1.05; letter-spacing: .04em; text-transform: uppercase;
  color: var(--text); margin: 0 0 6px;
}
.lm-art-cta-sub { font-size: 13px; color: var(--text-muted); margin: 0; }
.lm-art-cta-btn {
  display: inline-flex; align-items: center; gap: 8px; white-space: nowrap;
  padding: 13px 24px; background: var(--gold); border: none; border-radius: var(--radius);
  font-family: Impact,'Arial Black',sans-serif; font-size: 15px; letter-spacing: .1em; text-transform: uppercase;
  color: #0D0D10; text-decoration: none; transition: background .18s; flex-shrink: 0;
}
.lm-art-cta-btn:hover { background: var(--gold-lt); }

@media (max-width: 768px) {
  .lm-art-breadcrumb { padding: 12px 20px; }
  .lm-art-body { padding: 36px 20px 60px; }
  .lm-art-title { font-size: 36px; }
  .lm-art-content { font-size: 16px; }
  .lm-art-cta { flex-direction: column; align-items: flex-start; }
  .lm-art-hero-placeholder { height: 220px; }
  .lm-plate-lockup { font-size: 32px; gap: 10px; }
  .lm-plate-lockup .lm-plate-trophy { font-size: 27px; }
}
@media (prefers-reduced-motion:reduce) {
  .lm-art *,.lm-art *::before,.lm-art *::after { transition:none !important; }
}
</style>

<div class="lm-art">

  <nav class="lm-art-breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="lm-art-breadcrumb-sep" aria-hidden="true">›</span>
    <a href="{{ blog.url }}">{{ blog.title }}</a>
    <span class="lm-art-breadcrumb-sep" aria-hidden="true">›</span>
    <span>{{ article.title | truncate: 50 }}</span>
  </nav>

  {%- if article.image -%}
    <div class="lm-art-hero">
      <img src="{{ article.image | image_url: width: 1400 }}" alt="{{ article.image.alt | default: article.title | escape }}" loading="eager" width="1400">
    </div>
  {%- else -%}
    <div class="lm-art-hero-placeholder" aria-hidden="true">
      <div class="lm-plate">
        <div class="lm-plate-lockup"><span>League</span><span class="lm-plate-trophy">🏆</span><span>Mugs</span></div>
        <div class="lm-plate-rule"></div>
        <div class="lm-plate-sub">{{ blog.title }}</div>
      </div>
    </div>
  {%- endif -%}

  <div class="lm-art-body">

    <div class="lm-art-eyebrow">
      <i class="lm-art-eyebrow-bar" aria-hidden="true"></i>
      {{ blog.title }}
    </div>

    <h1 class="lm-art-title">{{ article.title }}</h1>

    <div class="lm-art-meta">
      <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: "%B %d, %Y" }}</time>
      {%- if article.tags.size > 0 -%}
        <span class="lm-art-meta-dot" aria-hidden="true"></span>
        <div class="lm-art-tags">
          {%- for tag in article.tags -%}
            <span class="lm-art-tag">{{ tag }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="lm-art-content">{{ article.content }}</div>

    <hr class="lm-art-rule" aria-hidden="true">

    <div class="lm-art-cta">
      <div>
        <p class="lm-art-cta-text">Your Championship Deserves a Mug</p>
        <p class="lm-art-cta-sub">Personalize with your league name and year. Ships in 3–5 days.</p>
      </div>
      <a class="lm-art-cta-btn" href="/collections/champions">Shop Champions &#8594;</a>
    </div>

  </div>

</div>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% schema %}
{"name":"LM Article","tag":"section","class":"lm-article-section","enabled_on":{"templates":["article"]},"settings":[],"presets":[{"name":"LM Article","category":"Blog"}]}
{% endschema %}
