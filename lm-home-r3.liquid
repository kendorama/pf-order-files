{%- comment -%} LeagueMugs bespoke homepage v12 — design-packet improvements. Self-contained. {%- endcomment -%}
<style>
@import url("https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap");
.lmx{--ob:#0D0D0D;--gold:#C9A84C;--goldh:#D8B85A;--off:#FAFAFA;--cream:#F5F0E8;--mid:#1A1A2E;
  --decay:#2E1E10;--tarn:#8B6A3A;--ink:#18181B;--ink2:#3F3F46;--ink3:#71717A;--hair:#E4E4E7;--red:#E8432A;--green:#2a4a2a;
  --disp:"Barlow Condensed",Impact,sans-serif;--body:"Inter",-apple-system,system-ui,sans-serif;}
.lmx *{box-sizing:border-box;margin:0}
.lmx{font-family:var(--body);color:var(--ink);line-height:1.65}
.lmx .bleed{position:relative;left:50%;right:50%;width:100vw;max-width:100vw;margin-left:-50vw;margin-right:-50vw}
.lmx .wrap{max-width:1240px;margin:0 auto;padding:0 40px}
.lmx .ey{font-family:var(--body);font-weight:600;font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold)}
.lmx .rule{display:block;width:60px;height:2px;background:var(--gold);border:0;margin:14px 0 18px}
.lmx .rule.c{margin-left:auto;margin-right:auto}
.lmx h2.t{font-family:var(--disp);font-weight:800;text-transform:uppercase;letter-spacing:.01em;line-height:1.0;font-size:42px;color:inherit}
.lmx .sub{font-family:var(--body);font-size:15px;color:var(--ink3);margin-top:12px;max-width:620px}
.lmx .btn{display:inline-block;font-family:var(--disp);font-weight:800;text-transform:uppercase;letter-spacing:.08em;
  font-size:15px;padding:15px 28px;border-radius:6px;text-decoration:none;transition:.18s;cursor:pointer}
.lmx .btn-gold{background:var(--gold);color:var(--ob);box-shadow:0 8px 28px rgba(201,168,76,.35)}
.lmx .btn-gold:hover{background:var(--goldh)}
.lmx .btn-out{border:1.5px solid rgba(255,255,255,.35);color:#fff}
.lmx .btn-out:hover{border-color:var(--gold);color:var(--gold)}
.lmx .btn-tarn{background:var(--tarn);color:var(--cream)}
.lmx .btn-tarn:hover{background:#9D7A45}

/* HERO */
.lmx .hero{background:linear-gradient(155deg,#1A1A2E 0%,#141425 45%,#0D0D0D 100%)}
.lmx .hero .wrap{display:grid;grid-template-columns:1.1fr .9fr;gap:48px;align-items:center;padding:88px 40px}
.lmx .hero h1{font-family:var(--disp);font-weight:800;text-transform:uppercase;letter-spacing:.01em;line-height:.96;font-size:74px;color:#fff}
.lmx .hero h1 .g{color:var(--gold)}
.lmx .hero p{font-size:17px;color:rgba(255,255,255,.74);margin-top:8px;max-width:440px}
.lmx .hero .cta{display:flex;gap:14px;margin-top:30px;flex-wrap:wrap}
.lmx .hero .fig{display:flex;justify-content:center}
.lmx .hero .fig img{max-width:100%;height:auto;filter:drop-shadow(0 26px 50px rgba(0,0,0,.6))}
.lmx .hero-context{display:inline-flex;align-items:center;gap:10px;margin-bottom:18px;
  background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.2);border-radius:4px;padding:6px 12px}
.lmx .hero-context .dot{width:6px;height:6px;border-radius:50%;background:var(--gold);animation:pulse 1.8s ease-in-out infinite}
.lmx .hero-context span{font-family:var(--disp);font-weight:700;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

/* TRUST */
.lmx .trust{background:var(--cream)}
.lmx .trust .wrap{display:flex;flex-wrap:wrap;justify-content:center;gap:14px 34px;padding:18px 40px}
.lmx .trust span{font-family:var(--body);font-weight:600;font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink2)}
.lmx .trust span::before{content:"\25C6";color:var(--gold);margin-right:10px;font-size:9px;vertical-align:middle}

/* TICKER */
.lmx .ticker{background:var(--ob);overflow:hidden;border-top:1px solid rgba(201,168,76,.18);border-bottom:1px solid rgba(201,168,76,.18)}
.lmx .ticker-track{display:flex;width:max-content;animation:tick 32s linear infinite}
.lmx .ticker-track:hover{animation-play-state:paused}
.lmx .ticker-track span{display:inline-block;font-family:var(--disp);font-weight:700;font-size:11px;
  letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.45);padding:10px 0;white-space:nowrap}
.lmx .ticker-track .sep{color:var(--gold);padding:10px 20px}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* BUNDLES */
.lmx .bundles{background:var(--ob);padding:84px 0}
.lmx .bundles .head{text-align:center;margin-bottom:40px}
.lmx .bundles h2.t{color:#fff}
.lmx .bundles .sub{color:rgba(255,255,255,.6);margin:12px auto 0}
.lmx .bgrid{display:grid;grid-template-columns:1fr 1fr;gap:26px}
.lmx .bcard{position:relative;border-radius:14px;overflow:hidden;display:grid;grid-template-columns:1fr 1fr;
  align-items:center;background:linear-gradient(135deg,#1A1A2E,#0D0D0D);border:1px solid rgba(201,168,76,.25)}
.lmx .bcard.lose{background:linear-gradient(135deg,#2E1E10,#1c1209);border-color:rgba(139,106,58,.35)}
.lmx .bcard .bimg{padding:26px;display:flex;justify-content:center}
.lmx .bcard .bimg img{max-width:170px;width:100%;filter:drop-shadow(0 12px 24px rgba(0,0,0,.5))}
.lmx .bcard .btxt{padding:26px 26px 26px 0}
.lmx .bcard .tag{font-family:var(--body);font-weight:700;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold)}
.lmx .bcard.lose .tag{color:var(--tarn)}
.lmx .bcard h3{font-family:var(--disp);font-weight:800;text-transform:uppercase;letter-spacing:.02em;font-size:26px;color:#fff;margin:8px 0 6px;line-height:1.02}
.lmx .bcard p{font-size:13px;color:rgba(255,255,255,.66);margin-bottom:16px}
.lmx .bcard .price{font-family:var(--disp);font-weight:800;color:#fff;font-size:20px;margin-bottom:14px}
.lmx .bcard .price small{font-weight:500;font-size:12px;color:rgba(255,255,255,.5);text-decoration:line-through;margin-left:8px;font-family:var(--body)}

/* GRID */
.lmx .sec{padding:84px 0;background:var(--off)}
.lmx .sec .wrap{max-width:1440px}
.lmx .sechead{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:18px;border-bottom:1px solid var(--hair);padding-bottom:22px}
.lmx .pills{display:flex;gap:10px;flex-wrap:wrap}
.lmx .pill{font-family:var(--body);font-weight:600;font-size:12px;letter-spacing:.12em;text-transform:uppercase;
  padding:9px 18px;border-radius:30px;border:1px solid var(--hair);color:var(--ink2);text-decoration:none;transition:.15s}
.lmx .pill:hover{border-color:var(--ob);color:var(--ob)}
.lmx .pill.on{background:var(--ob);color:#fff;border-color:var(--ob)}
.lmx .lmgrid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:26px;margin-top:34px}
.lmx .lmcard{background:#fff;min-width:0;border:1px solid var(--hair);border-radius:12px;overflow:hidden;
  text-decoration:none;color:inherit;display:flex;flex-direction:column;transition:.2s;box-shadow:0 2px 8px rgba(13,13,13,.06)}
.lmx .lmcard:hover{transform:translateY(-4px);box-shadow:0 16px 36px rgba(13,13,13,.12)}
.lmx .lmcard .ph{position:relative;aspect-ratio:1/1;background:var(--cream);display:flex;align-items:center;justify-content:center;overflow:hidden}
.lmx .lmcard .ph img{width:84%;height:84%;object-fit:contain;transition:.25s}
.lmx .lmcard:hover .ph img{transform:scale(1.04)}
.lmx .badge{position:absolute;top:12px;left:12px;font-family:var(--disp);font-weight:800;text-transform:uppercase;
  letter-spacing:.06em;font-size:10px;padding:4px 9px;border-radius:3px;background:var(--gold);color:var(--ob)}
.lmx .badge.new{background:var(--red);color:#fff}
.lmx .lmcard .meta{padding:16px 16px 20px;display:flex;flex-direction:column;flex:1}

/* REPORT BADGE — category stamp system from the brief */
.lmx .rpbadge{display:inline-flex;align-items:center;gap:5px;font-family:var(--disp);font-weight:800;
  text-transform:uppercase;letter-spacing:.1em;font-size:9px;padding:3px 8px;border-radius:2px;margin-bottom:8px;width:fit-content}
.lmx .rpbadge::before{content:"▶";font-size:5px}
.lmx .rpbadge.champ{background:var(--gold);color:var(--ob)}
.lmx .rpbadge.roast{background:var(--tarn);color:var(--cream)}
.lmx .rpbadge.report{background:var(--red);color:#fff}
.lmx .rpbadge.commish{background:var(--mid);color:var(--gold);border:1px solid rgba(201,168,76,.3)}
.lmx .rpbadge.league{background:#1a3a1a;color:#6FCF97;border:1px solid rgba(111,207,154,.25)}

.lmx .lmcard .pt{font-family:var(--disp);font-weight:700;text-transform:uppercase;letter-spacing:.03em;font-size:19px;margin-bottom:4px;line-height:1.15;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;min-height:1.15em}
.lmx .lmcard .tagline{font-family:var(--body);font-style:italic;font-size:11.5px;color:var(--ink3);line-height:1.35;margin-bottom:10px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;height:2.7em}
.lmx .lmcard .pr{font-family:var(--disp);font-weight:800;font-size:22px;margin-top:auto}

/* LEAGUE STARTER PACK */
.lmx .starter{background:var(--mid);padding:84px 0}
.lmx .starter .wrap{display:grid;grid-template-columns:1fr 1.1fr;gap:64px;align-items:center}
.lmx .starter .ey{color:rgba(201,168,76,.85)}
.lmx .starter .rule{background:var(--gold)}
.lmx .starter h2.t{color:#fff}
.lmx .starter .sub{color:rgba(255,255,255,.62)}
.lmx .starter-badge{display:inline-flex;align-items:center;gap:10px;
  background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.25);
  border-radius:6px;padding:10px 16px;margin:20px 0 28px}
.lmx .starter-badge span{font-family:var(--body);font-size:11px;font-weight:700;
  color:rgba(201,168,76,.9);letter-spacing:.08em;text-transform:uppercase}
.lmx .starter-steps{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:32px}
.lmx .step{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:18px}
.lmx .step-n{font-family:var(--disp);font-weight:800;font-size:30px;color:var(--gold);line-height:1}
.lmx .step-t{font-family:var(--disp);font-weight:700;text-transform:uppercase;font-size:13px;letter-spacing:.04em;color:#fff;margin:5px 0 3px}
.lmx .step-d{font-size:11.5px;color:rgba(255,255,255,.45);line-height:1.4}
.lmx .starter-cta{display:flex;gap:14px;flex-wrap:wrap}
.lmx .starter-fig{display:flex;justify-content:center;align-items:center}
.lmx .starter-fig img{max-width:380px;width:100%;filter:drop-shadow(0 28px 56px rgba(0,0,0,.55))}

/* ROAST */
.lmx .roast{background:var(--decay)}
.lmx .roast .wrap{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;padding:80px 40px}
.lmx .roast .fig{display:flex;justify-content:center}
.lmx .roast .fig img{max-width:340px;width:100%;height:auto;filter:drop-shadow(0 18px 36px rgba(0,0,0,.5))}
.lmx .roast .ey{color:var(--tarn)}
.lmx .roast .rule{background:var(--tarn)}
.lmx .roast h2{font-family:var(--disp);font-weight:800;text-transform:uppercase;letter-spacing:.01em;font-size:42px;color:var(--cream);line-height:1.0}
.lmx .roast p{color:rgba(245,240,232,.78);font-size:15px;margin:16px 0 26px;max-width:480px}

/* NEWSLETTER */
.lmx .nl{background:var(--ob)}
.lmx .nl .wrap{padding:74px 40px;text-align:center}
.lmx .nl h2{color:#fff}
.lmx .nl p{color:rgba(255,255,255,.72);font-size:15px;margin:12px auto 24px;max-width:480px}
.lmx .nl form{display:flex;gap:10px;max-width:480px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.lmx .nl input{flex:1;min-width:240px;padding:14px 18px;border-radius:6px;border:1px solid rgba(255,255,255,.18);
  background:rgba(255,255,255,.06);color:#fff;font-family:var(--body);font-size:14px}
.lmx .nl input::placeholder{color:rgba(255,255,255,.5)}

@media(max-width:900px){
  .lmx .hero .wrap,.lmx .roast .wrap,.lmx .bgrid,.lmx .starter .wrap{grid-template-columns:1fr}
  .lmx .hero{text-align:center}.lmx .hero h1{font-size:52px}.lmx .hero .cta{justify-content:center}
  .lmx .hero p,.lmx .hero-context{margin-left:auto;margin-right:auto}.lmx .hero .fig{order:-1}
  .lmx .roast .fig{order:-1}
  .lmx .lmgrid{grid-template-columns:repeat(2,1fr)}
  .lmx .bcard{grid-template-columns:1fr;text-align:center}.lmx .bcard .btxt{padding:0 26px 28px}
  .lmx .starter .wrap{gap:40px}.lmx .starter-fig{order:-1}
  .lmx .starter-badge{margin-left:auto;margin-right:auto}
  .lmx .rpbadge{margin-left:auto;margin-right:auto}
}
@media(max-width:520px){
  .lmx .lmgrid{grid-template-columns:1fr}.lmx .hero h1{font-size:42px}.lmx h2.t{font-size:32px}.lmx .wrap{padding:0 22px}
  .lmx .starter-steps{grid-template-columns:1fr}
}
</style>

