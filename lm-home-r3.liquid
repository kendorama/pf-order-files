          <div class="pr">$19.99</div>
        </div>
      </a>

      <a class="lmcard" href="/products/last-place-toilet-bowl-sacko-mug">
        <div class="ph"><span class="badge new">New</span><img src="{{ p_sacko.featured_image | image_url: width: 500 }}" alt="Toilet Bowl Sacko mug" width="500" height="500"></div>
        <div class="meta">
          <span class="rpbadge roast">Dead Last</span>
          <div class="pt">Toilet Bowl Sacko</div>
          <div class="tagline">Dead last, forever documented.</div>
          <div class="pr">$19.99</div>
        </div>
      </a>

      <a class="lmcard" href="/products/trade-menace-mug">
        <div class="ph"><img src="{{ p_trade.featured_image | image_url: width: 500 }}" alt="Trade Menace mug" width="500" height="500"></div>
        <div class="meta">
          <span class="rpbadge report">Trade Desk</span>
          <div class="pt">Trade Menace</div>
          <div class="tagline">Trade menace behavior. Documented.</div>
          <div class="pr">$19.99</div>
